output "project_name" {
  description = "Project name used for resources."
  value       = var.project_name
}

output "environment" {
  description = "Environment name."
  value       = var.environment
}

output "aws_region" {
  description = "AWS region for this environment."
  value       = var.aws_region
}

output "cluster_name" {
  description = "Planned EKS cluster name."
  value       = var.cluster_name
}

output "network_name_prefix" {
  description = "Name prefix generated by the network module."
  value       = module.network.name_prefix
}

output "network_vpc_cidr" {
  description = "VPC CIDR passed to the network module."
  value       = module.network.vpc_cidr
}

output "eks_cluster_full_name" {
  description = "Full cluster name generated by the EKS module."
  value       = module.eks.cluster_full_name
}

output "eks_kubernetes_version" {
  description = "Kubernetes version configured by the EKS module."
  value       = module.eks.kubernetes_version
}
